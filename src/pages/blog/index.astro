---
import PublicLayout from '../../layouts/PublicLayout.astro';
import Section from '../../components/ui/Section.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Card from '../../components/ui/Card.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/ui/Button.astro';
---

<PublicLayout
  title="Blog | The Sauna Guys"
  description="Expert articles on sauna benefits, cold plunge science, contrast therapy, and Tampa wellness. Evidence-based content for your recovery journey."
>
  <!-- Blog Header -->
  <Section variant="light">
    <SectionHeading title="Blog" subtitle="Wellness tips and studio updates" />

    <!-- Featured Guides -->
    <h3 class="text-center text-lg font-bold uppercase tracking-wider text-dark-teal mb-8">Start Here</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      <a href="/sauna-benefits" class="group block">
        <Card variant="clay" class="p-8 h-full">
          <span class="text-xs font-bold uppercase tracking-wider text-teal mb-2 block">Complete Guide</span>
          <h3 class="text-xl mb-3 group-hover:text-teal transition-colors">Sauna Benefits</h3>
          <p class="text-gray-600 text-sm">The science-backed breakdown of how sauna sessions improve cardiovascular health, recovery, sleep, and more.</p>
        </Card>
      </a>
      <a href="/cold-plunge-guide" class="group block">
        <Card variant="clay" class="p-8 h-full">
          <span class="text-xs font-bold uppercase tracking-wider text-teal mb-2 block">Complete Guide</span>
          <h3 class="text-xl mb-3 group-hover:text-teal transition-colors">Cold Plunge Guide</h3>
          <p class="text-gray-600 text-sm">Everything you need to know about cold water immersion — benefits, protocols, safety, and how to build your practice.</p>
        </Card>
      </a>
      <a href="/contrast-therapy" class="group block">
        <Card variant="clay" class="p-8 h-full">
          <span class="text-xs font-bold uppercase tracking-wider text-teal mb-2 block">Complete Guide</span>
          <h3 class="text-xl mb-3 group-hover:text-teal transition-colors">Contrast Therapy</h3>
          <p class="text-gray-600 text-sm">Why alternating between hot and cold is the ultimate recovery hack — and the science behind how it works.</p>
        </Card>
      </a>
    </div>

    <!-- Blog Posts Placeholder -->
    <SectionHeading title="Latest Articles" />
    <div class="max-w-2xl mx-auto text-center">
      <Card variant="clay" class="p-12">
        <p class="text-gray-600 text-lg mb-6">
          Blog posts coming soon — subscribe to be notified.
        </p>
        <!-- Email Signup Placeholder -->
        <form name="blog-subscribe" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input type="hidden" name="form-name" value="blog-subscribe" />
          <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
          <input
            type="email"
            name="email"
            placeholder="Your email address"
            required
            class="flex-grow px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-teal"
          />
          <Button type="submit" variant="primary">
            Notify Me
          </Button>
        </form>
      </Card>
    </div>

    <!-- Blog Post Grid (for future content collection) -->
    <!--
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-16">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="group block">
          <Card variant="clay" class="overflow-hidden h-full">
            <div class="aspect-video bg-gray-200"></div>
            <div class="p-6">
              <span class="text-xs font-bold uppercase tracking-wider text-teal mb-2 block">{post.data.category}</span>
              <h3 class="text-lg mb-2 group-hover:text-teal transition-colors">{post.data.title}</h3>
              <p class="text-gray-600 text-sm">{post.data.description}</p>
            </div>
          </Card>
        </a>
      ))}
    </div>
    -->
  </Section>
</PublicLayout>
