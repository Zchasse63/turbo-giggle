---
import PublicLayout from '../layouts/PublicLayout.astro';
---

<PublicLayout
  title="Sauna & Cold Plunge Tampa | The Sauna Guys"
  description="Tampa's premier sauna and cold plunge wellness studio. Guided contrast therapy sessions for recovery, stress relief, and total body wellness."
>
  <!-- Hero Section -->
  <section class="section-dark py-24 md:py-32">
    <div class="container text-center">
      <h1 class="text-white mb-6">Tampa's Premier<br />Sauna & Cold Plunge</h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto mb-8">
        Guided contrast therapy sessions designed for recovery, stress relief, and total body wellness.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={import.meta.env.PUBLIC_GLOWFOX_CLASSES_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 bg-teal text-black font-bold uppercase tracking-wider rounded-[60px] hover:brightness-110 transition-all duration-200"
        >
          Book a Session
        </a>
        <a
          href="/first-visit"
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-bold uppercase tracking-wider rounded-[60px] hover:bg-white/10 transition-all duration-200"
        >
          First Time? Start Here
        </a>
      </div>
    </div>
  </section>

  <!-- Accent Line -->
  <div class="accent-line"></div>

  <!-- Services Preview -->
  <section class="section-light py-20">
    <div class="container text-center">
      <h2 class="mb-12">What We Offer</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-gold/10 rounded-[20px] p-8 shadow-[var(--shadow-clay)]">
          <h3 class="text-2xl mb-4">Sauna</h3>
          <p>Traditional Finnish sauna sessions to detox, relax, and rejuvenate.</p>
        </div>
        <div class="bg-gold/10 rounded-[20px] p-8 shadow-[var(--shadow-clay)]">
          <h3 class="text-2xl mb-4">Cold Plunge</h3>
          <p>Invigorating cold water immersion for recovery and mental clarity.</p>
        </div>
        <div class="bg-gold/10 rounded-[20px] p-8 shadow-[var(--shadow-clay)]">
          <h3 class="text-2xl mb-4">Contrast Therapy</h3>
          <p>Guided hot-cold cycles for the ultimate wellness experience.</p>
        </div>
      </div>
    </div>
  </section>
</PublicLayout>
