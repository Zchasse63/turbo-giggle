---
import PublicLayout from '../../layouts/PublicLayout.astro';
import HeroImage from '../../components/ui/HeroImage.astro';
import Section from '../../components/ui/Section.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Card from '../../components/ui/Card.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/ui/Button.astro';

const bookingUrl = import.meta.env.PUBLIC_GLOWFOX_CLASSES_URL;
const membershipUrl = import.meta.env.PUBLIC_GLOWFOX_MEMBERSHIPS_URL;

const neighborhoodName = "Downtown Tampa";
const pageSlug = "downtown-tampa";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thesaunaguys.com/" },
    { "@type": "ListItem", "position": 2, "name": `Sauna Near ${neighborhoodName}`, "item": `https://thesaunaguys.com/near/${pageSlug}` }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I get to The Sauna Guys from Downtown Tampa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Head east on Adamo Drive (SR-60) from the downtown core. The studio is about 8 minutes away at 1703 N 24th Street, right off the Ybor/Heights corridor. No interstate needed."
      }
    },
    {
      "@type": "Question",
      "name": "Can I come before or after work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. We open at 6 AM on weekdays, so you can fit in a session before your first meeting. Evening sessions run until 8 PM — perfect for decompressing after the workday."
      }
    },
    {
      "@type": "Question",
      "name": "What is contrast therapy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Contrast therapy alternates between sauna heat (190\u00b0F+) and cold plunge immersion. This hot-cold cycle boosts circulation, reduces inflammation, and triggers a deep recovery response. Many downtown professionals use it for stress relief and mental clarity."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer corporate wellness packages?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! We offer private group bookings for corporate teams. Contact us at theguys@sauna-guys.com for custom pricing and availability."
      }
    }
  ]
};
---

<PublicLayout
  title="Sauna Near Downtown Tampa | The Sauna Guys Tampa"
  description="Sauna and cold plunge just 8 minutes from Downtown Tampa. Near Water Street, Channelside, and the Convention Center. Book your session now."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <HeroImage src="/images/exterior.jpg" alt="The Sauna Guys studio near Downtown Tampa" height="medium">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Sauna & Cold Plunge — 8 Minutes from Downtown Tampa</h1>
    <p class="text-lg md:text-xl max-w-2xl mx-auto mb-8">
      Escape the downtown grind without a long commute. Our studio is a straight shot from Water Street, Channelside, and the Tampa Convention Center — no highway needed.
      New to contrast therapy? Check out our <a href="/first-visit" class="underline font-semibold">first visit guide</a>.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href={bookingUrl} variant="on-dark" target="_blank">Book a Session</Button>
      <Button href="#location" variant="outline">Get Directions</Button>
    </div>
  </HeroImage>

  <div class="accent-line"></div>

  <!-- Quick Facts -->
  <Section variant="warm" id="quick-facts">
    <div class="max-w-3xl mx-auto">
      <Card variant="clay" class="p-8">
        <h2 class="text-2xl font-bold mb-6 text-center">Getting Here from Downtown</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="flex items-start gap-3">
            <Icon name="clock" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">8-Minute Drive</p>
              <p class="text-gray-600 text-sm">Head east on Adamo Drive (SR-60) and you're here. Simple, direct, and no interstate required.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <Icon name="map-pin" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">1703 N 24th Street</p>
              <p class="text-gray-600 text-sm">Nestled between Ybor City and the Heights, with easy access from the Selmon Expressway.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <Icon name="compass" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">Free On-Site Parking</p>
              <p class="text-gray-600 text-sm">No downtown parking rates here. Pull into our free dedicated lot and walk right in.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <Icon name="calendar" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">Early Morning Sessions</p>
              <p class="text-gray-600 text-sm">Doors open at 6 AM on weekdays. Get a session in before the first meeting of the day.</p>
            </div>
          </div>
        </div>
      </Card>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Why Choose Us -->
  <Section variant="light" id="why-choose-us">
    <SectionHeading title="Why Downtown Professionals Choose Us" subtitle="Your most productive meeting of the day might be with a 190-degree sauna" />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="zap" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Stress Relief</h3>
        <p class="text-gray-600 text-sm">Downtown work is demanding. A contrast therapy session resets your nervous system, helping you handle deadlines and long hours with clarity.</p>
      </Card>
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="brain" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Mental Sharpness</h3>
        <p class="text-gray-600 text-sm">Cold plunge exposure triggers norepinephrine release, boosting focus and attention. Many of our downtown regulars swear by a pre-work session.</p>
      </Card>
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="timer" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Efficient Recovery</h3>
        <p class="text-gray-600 text-sm">Full 60-minute sessions with showers included. Get in, sweat, plunge, rinse, and get back to the office feeling recharged.</p>
      </Card>
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="moon" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Better Sleep</h3>
        <p class="text-gray-600 text-sm">Evening sessions after work promote deeper, more restorative sleep. Trade the nightcap for a hot-cold cycle and feel the difference.</p>
      </Card>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Sessions Overview -->
  <Section variant="dark" id="sessions">
    <SectionHeading title="Pick Your Experience" subtitle="Structured or self-paced, we have a session that fits your schedule" light />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <Card variant="dark" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="compass" size={36} class="text-teal" />
        </div>
        <h3 class="text-xl mb-2 text-white">1-Hour Guided</h3>
        <p class="text-white/70 text-sm mb-4">Instructor-led sauna rounds with breathwork coaching. Our guides handle the timing so you just show up and let go.</p>
        <Button href="/services" variant="on-dark">Learn More</Button>
      </Card>
      <Card variant="dark" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="sun" size={36} class="text-teal" />
        </div>
        <h3 class="text-xl mb-2 text-white">1-Hour Open</h3>
        <p class="text-white/70 text-sm mb-4">Full facility access, your pace. Grab a plunge, sit in the heat, repeat. No structure needed when you know the ropes.</p>
        <Button href="/services" variant="on-dark">Learn More</Button>
      </Card>
      <Card variant="dark" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="users" size={36} class="text-teal" />
        </div>
        <h3 class="text-xl mb-2 text-white">Women's Group</h3>
        <p class="text-white/70 text-sm mb-4">A guided experience in a women-only setting. A supportive space to unwind, connect, and recover together.</p>
        <Button href="/services" variant="on-dark">Learn More</Button>
      </Card>
    </div>
    <p class="text-center mt-6 text-white/60">
      First time? Read our <a href="/first-visit" class="text-teal underline hover:text-white transition-colors">complete first visit guide</a> to know exactly what to expect.
    </p>
  </Section>

  <div class="accent-line"></div>

  <!-- Pricing CTA -->
  <Section variant="warm" id="intro-offer">
    <div class="max-w-xl mx-auto text-center">
      <Card variant="gold" class="p-8 relative">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-dark-teal text-white text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full whitespace-nowrap">
          Best for First-Timers
        </span>
        <div class="flex justify-center mb-3">
          <Icon name="gift" size={36} class="text-dark-teal" />
        </div>
        <h2 class="text-2xl font-bold mb-2">The Sauna Sampler</h2>
        <p class="text-5xl font-bold text-dark-teal mb-2">$60</p>
        <p class="text-black/70 mb-1">3 sessions to try us out</p>
        <p class="text-black/60 text-sm mb-6">One flat price, three full sessions. Many of our downtown members started right here, then never looked back.</p>
        <Button href={membershipUrl} variant="secondary" target="_blank">Get the Sampler</Button>
      </Card>
    </div>
  </Section>

  <!-- FAQ -->
  <div class="accent-line"></div>
  <Section variant="light" id="faq">
    <SectionHeading title="Frequently Asked Questions" subtitle="Common questions from Downtown Tampa visitors" />
    <div class="max-w-3xl mx-auto space-y-4">
      <details class="group" open>
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>How do I get to The Sauna Guys from Downtown Tampa?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>Head east on Adamo Drive (SR-60) from the downtown core. The studio is about 8 minutes away at 1703 N 24th Street, right off the Ybor/Heights corridor. No interstate needed.</p>
        </div>
      </details>
      <details class="group">
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>Can I come before or after work?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>Absolutely. We open at 6 AM on weekdays, so you can fit in a session before your first meeting. Evening sessions run until 8 PM — perfect for decompressing after the workday.</p>
        </div>
      </details>
      <details class="group">
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>What is contrast therapy?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>Contrast therapy alternates between sauna heat (190°F+) and cold plunge immersion. This hot-cold cycle boosts circulation, reduces inflammation, and triggers a deep recovery response. Many downtown professionals use it for stress relief and mental clarity.</p>
        </div>
      </details>
      <details class="group">
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>Do you offer corporate wellness packages?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>Yes! We offer private group bookings for corporate teams. Contact us at <a href="mailto:theguys@sauna-guys.com" class="text-teal underline hover:text-dark-teal">theguys@sauna-guys.com</a> for custom pricing and availability.</p>
        </div>
      </details>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Google Maps -->
  <Section variant="light" id="location">
    <SectionHeading title="Find Us from Downtown Tampa" subtitle="Head east on Adamo Drive — you'll be here in under 10 minutes" />
    <div class="rounded-[var(--radius-card)] overflow-hidden shadow-lg">
      <iframe
        src="https://maps.google.com/maps?q=1703+N+24th+St,+Tampa,+FL+33605&t=&z=13&ie=UTF8&iwloc=&output=embed"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Map showing The Sauna Guys location near Downtown Tampa"
      ></iframe>
    </div>
    <div class="mt-6 text-center">
      <p class="text-gray-600 mb-2">
        <Icon name="map-pin" size={18} class="inline text-teal" /> 1703 North 24th Street, Tampa, FL 33605
      </p>
      <p class="text-gray-600 mb-2">
        <Icon name="phone" size={18} class="inline text-teal" /> <a href="tel:8135514177" class="text-teal hover:underline">(813) 551-4177</a>
      </p>
      <p class="text-gray-600">
        <Icon name="mail" size={18} class="inline text-teal" /> <a href="mailto:hello@thesaunaguys.com" class="text-teal hover:underline">hello@thesaunaguys.com</a>
      </p>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Nearby Neighborhoods -->
  <Section variant="teal" id="nearby">
    <SectionHeading title="Explore More Neighborhoods" subtitle="We're a short drive from communities across the Tampa Bay area" />
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 max-w-4xl mx-auto">
      <a href="/near/south-tampa" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">South Tampa</p>
        <p class="text-xs text-gray-600">10 min drive</p>
      </a>
      <a href="/near/ybor-city" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Ybor City</p>
        <p class="text-xs text-gray-600">7 min drive</p>
      </a>
      <a href="/near/seminole-heights" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Seminole Heights</p>
        <p class="text-xs text-gray-600">10 min drive</p>
      </a>
      <a href="/near/westchase" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Westchase</p>
        <p class="text-xs text-gray-600">15 min drive</p>
      </a>
      <a href="/near/brandon" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Brandon</p>
        <p class="text-xs text-gray-600">20 min drive</p>
      </a>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Bottom CTA -->
  <Section variant="dark" id="book-now">
    <div class="text-center">
      <SectionHeading
        title="Take a Real Break"
        subtitle="Step away from the screens and into 190 degrees of pure reset. Downtown Tampa's best-kept wellness secret is waiting."
        light
      />
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={bookingUrl} variant="on-dark" target="_blank">Book a Session</Button>
        <Button href={membershipUrl} variant="outline" target="_blank">View Memberships</Button>
      </div>
    </div>
  </Section>
</PublicLayout>
