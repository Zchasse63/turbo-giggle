---
import PublicLayout from '../../layouts/PublicLayout.astro';
import HeroImage from '../../components/ui/HeroImage.astro';
import Section from '../../components/ui/Section.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Card from '../../components/ui/Card.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/ui/Button.astro';

const bookingUrl = import.meta.env.PUBLIC_GLOWFOX_CLASSES_URL;
const membershipUrl = import.meta.env.PUBLIC_GLOWFOX_MEMBERSHIPS_URL;

const neighborhoodName = "South Tampa";
const pageSlug = "south-tampa";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thesaunaguys.com/" },
    { "@type": "ListItem", "position": 2, "name": `Sauna Near ${neighborhoodName}`, "item": `https://thesaunaguys.com/near/${pageSlug}` }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How far is The Sauna Guys from South Tampa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our studio at 1703 N 24th Street is about a 10-minute drive from the Hyde Park and Davis Islands area. Take the Selmon Expressway east or head up Dale Mabry — both routes are quick and direct."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need to book in advance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, we recommend booking online to guarantee your spot, especially for guided sessions which tend to fill up. Open sessions are more flexible but still benefit from a reservation."
      }
    },
    {
      "@type": "Question",
      "name": "What should I bring to my first session?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Just bring a swimsuit and a positive attitude. We provide towels, filtered water, and full shower facilities. Check our first visit guide for a complete list of what to expect."
      }
    },
    {
      "@type": "Question",
      "name": "Is there parking at the studio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, we have a free dedicated parking lot right at the studio. No meters, no garages — just pull in and walk through the front door."
      }
    }
  ]
};
---

<PublicLayout
  title="Sauna Near South Tampa | The Sauna Guys Tampa"
  description="Looking for a sauna near South Tampa? The Sauna Guys is just 10 minutes from Hyde Park, Davis Islands, and Bayshore Blvd. Book your session today."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <HeroImage src="/images/woman-sauna.jpg" alt="Relaxing sauna session at The Sauna Guys near South Tampa" height="medium">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Tampa's Premier Sauna & Cold Plunge — Just 10 Minutes from South Tampa</h1>
    <p class="text-lg md:text-xl max-w-2xl mx-auto mb-8">
      Skip the traffic on Bayshore. Our studio on North 24th Street puts world-class heat therapy and cold plunge pools right around the corner from Hyde Park, Davis Islands, and SoHo.
      New to contrast therapy? Check out our <a href="/first-visit" class="underline font-semibold">first visit guide</a>.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href={bookingUrl} variant="on-dark" target="_blank">Book a Session</Button>
      <Button href="#location" variant="outline">Get Directions</Button>
    </div>
  </HeroImage>

  <div class="accent-line"></div>

  <!-- Quick Facts -->
  <Section variant="warm" id="quick-facts">
    <div class="max-w-3xl mx-auto">
      <Card variant="clay" class="p-8">
        <h2 class="text-2xl font-bold mb-6 text-center">Getting Here from South Tampa</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="flex items-start gap-3">
            <Icon name="clock" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">10-Minute Drive</p>
              <p class="text-gray-600 text-sm">A quick hop across the Crosstown Expressway or up Dale Mabry from the Hyde Park area.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <Icon name="map-pin" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">1703 N 24th Street</p>
              <p class="text-gray-600 text-sm">Located in Tampa's Ybor/Heights corridor, easily accessible from Bayshore Blvd.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <Icon name="compass" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">Free On-Site Parking</p>
              <p class="text-gray-600 text-sm">Dedicated lot right at the studio. No meters, no garages, no stress.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <Icon name="calendar" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">Open 7 Days a Week</p>
              <p class="text-gray-600 text-sm">Mon-Fri 6 AM - 8 PM, Sat-Sun 8 AM - 6 PM. Sessions fit any schedule.</p>
            </div>
          </div>
        </div>
      </Card>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Why Choose Us -->
  <Section variant="light" id="why-choose-us">
    <SectionHeading title="Why South Tampa Locals Choose Us" subtitle="Real heat. Real cold. Real results — without leaving the Tampa Bay area." />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="thermometer-sun" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Traditional Dry Sauna</h3>
        <p class="text-gray-600 text-sm">Our Finnish-style barrel sauna reaches 190 F+ for the deep, penetrating heat that active South Tampa residents crave after morning runs along Bayshore.</p>
      </Card>
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="snowflake" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Cold Plunge Pools</h3>
        <p class="text-gray-600 text-sm">Multiple tubs maintained at bracing temperatures. The perfect contrast to Florida heat, and far more effective than a Bay swim.</p>
      </Card>
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="users" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Welcoming Community</h3>
        <p class="text-gray-600 text-sm">Join regulars from Hyde Park, Palma Ceia, and Davis Islands who've made The Sauna Guys part of their weekly wellness routine.</p>
      </Card>
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="shield-check" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Clean & Professional</h3>
        <p class="text-gray-600 text-sm">Spotless facilities, fresh towels, and full showers every session. A boutique experience without the spa price tag.</p>
      </Card>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Sessions Overview -->
  <Section variant="dark" id="sessions">
    <SectionHeading title="Choose Your Session" subtitle="Three ways to experience sauna and cold plunge therapy" light />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <Card variant="dark" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="compass" size={36} class="text-teal" />
        </div>
        <h3 class="text-xl mb-2 text-white">1-Hour Guided</h3>
        <p class="text-white/70 text-sm mb-4">Expert-led sauna rounds with breathwork coaching and cold plunge guidance. Ideal if you're new to contrast therapy.</p>
        <Button href="/services" variant="on-dark">Learn More</Button>
      </Card>
      <Card variant="dark" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="sun" size={36} class="text-teal" />
        </div>
        <h3 class="text-xl mb-2 text-white">1-Hour Open</h3>
        <p class="text-white/70 text-sm mb-4">Full facility access at your own pace. Set your own rounds and timing. Perfect for experienced plungers.</p>
        <Button href="/services" variant="on-dark">Learn More</Button>
      </Card>
      <Card variant="dark" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="users" size={36} class="text-teal" />
        </div>
        <h3 class="text-xl mb-2 text-white">Women's Group</h3>
        <p class="text-white/70 text-sm mb-4">A guided session in a women-only environment. Welcoming, supportive, and empowering.</p>
        <Button href="/services" variant="on-dark">Learn More</Button>
      </Card>
    </div>
    <p class="text-center mt-6 text-white/60">
      First time? Read our <a href="/first-visit" class="text-teal underline hover:text-white transition-colors">complete first visit guide</a> to know exactly what to expect.
    </p>
  </Section>

  <div class="accent-line"></div>

  <!-- Pricing CTA -->
  <Section variant="warm" id="intro-offer">
    <div class="max-w-xl mx-auto text-center">
      <Card variant="gold" class="p-8 relative">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-dark-teal text-white text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full whitespace-nowrap">
          Best for First-Timers
        </span>
        <div class="flex justify-center mb-3">
          <Icon name="gift" size={36} class="text-dark-teal" />
        </div>
        <h2 class="text-2xl font-bold mb-2">The Sauna Sampler</h2>
        <p class="text-5xl font-bold text-dark-teal mb-2">$60</p>
        <p class="text-black/70 mb-1">3 sessions to try us out</p>
        <p class="text-black/60 text-sm mb-6">No commitment, no subscription. Just three full sessions to experience what South Tampa locals are raving about.</p>
        <Button href={membershipUrl} variant="secondary" target="_blank">Get the Sampler</Button>
      </Card>
    </div>
  </Section>

  <!-- FAQ -->
  <div class="accent-line"></div>
  <Section variant="light" id="faq">
    <SectionHeading title="Frequently Asked Questions" subtitle="Common questions from South Tampa visitors" />
    <div class="max-w-3xl mx-auto space-y-4">
      <details class="group" open>
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>How far is The Sauna Guys from South Tampa?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>Our studio at 1703 N 24th Street is about a 10-minute drive from the Hyde Park and Davis Islands area. Take the Selmon Expressway east or head up Dale Mabry — both routes are quick and direct.</p>
        </div>
      </details>
      <details class="group">
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>Do I need to book in advance?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>Yes, we recommend booking online to guarantee your spot, especially for guided sessions which tend to fill up. Open sessions are more flexible but still benefit from a reservation.</p>
        </div>
      </details>
      <details class="group">
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>What should I bring to my first session?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>Just bring a swimsuit and a positive attitude. We provide towels, filtered water, and full shower facilities. Check our <a href="/first-visit" class="text-teal underline hover:text-dark-teal">first visit guide</a> for a complete list of what to expect.</p>
        </div>
      </details>
      <details class="group">
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>Is there parking at the studio?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>Yes, we have a free dedicated parking lot right at the studio. No meters, no garages — just pull in and walk through the front door.</p>
        </div>
      </details>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Google Maps -->
  <Section variant="light" id="location">
    <SectionHeading title="Find Us from South Tampa" subtitle="A quick drive across the Crosstown — free parking when you arrive" />
    <div class="rounded-[var(--radius-card)] overflow-hidden shadow-lg">
      <iframe
        src="https://maps.google.com/maps?q=1703+N+24th+St,+Tampa,+FL+33605&t=&z=13&ie=UTF8&iwloc=&output=embed"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Map showing The Sauna Guys location near South Tampa"
      ></iframe>
    </div>
    <div class="mt-6 text-center">
      <p class="text-gray-600 mb-2">
        <Icon name="map-pin" size={18} class="inline text-teal" /> 1703 North 24th Street, Tampa, FL 33605
      </p>
      <p class="text-gray-600 mb-2">
        <Icon name="phone" size={18} class="inline text-teal" /> <a href="tel:8135514177" class="text-teal hover:underline">(813) 551-4177</a>
      </p>
      <p class="text-gray-600">
        <Icon name="mail" size={18} class="inline text-teal" /> <a href="mailto:hello@thesaunaguys.com" class="text-teal hover:underline">hello@thesaunaguys.com</a>
      </p>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Nearby Neighborhoods -->
  <Section variant="teal" id="nearby">
    <SectionHeading title="Explore More Neighborhoods" subtitle="We're conveniently located near many Tampa communities" />
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 max-w-4xl mx-auto">
      <a href="/near/downtown-tampa" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Downtown Tampa</p>
        <p class="text-xs text-gray-600">8 min drive</p>
      </a>
      <a href="/near/ybor-city" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Ybor City</p>
        <p class="text-xs text-gray-600">7 min drive</p>
      </a>
      <a href="/near/seminole-heights" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Seminole Heights</p>
        <p class="text-xs text-gray-600">10 min drive</p>
      </a>
      <a href="/near/westchase" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Westchase</p>
        <p class="text-xs text-gray-600">15 min drive</p>
      </a>
      <a href="/near/brandon" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Brandon</p>
        <p class="text-xs text-gray-600">20 min drive</p>
      </a>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Bottom CTA -->
  <Section variant="dark" id="book-now">
    <div class="text-center">
      <SectionHeading
        title="Ready to Sweat?"
        subtitle="South Tampa's favorite post-workout recovery is waiting for you. Book your first session today."
        light
      />
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={bookingUrl} variant="on-dark" target="_blank">Book a Session</Button>
        <Button href={membershipUrl} variant="outline" target="_blank">View Memberships</Button>
      </div>
    </div>
  </Section>
</PublicLayout>
