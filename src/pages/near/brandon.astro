---
import PublicLayout from '../../layouts/PublicLayout.astro';
import HeroImage from '../../components/ui/HeroImage.astro';
import Section from '../../components/ui/Section.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Card from '../../components/ui/Card.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/ui/Button.astro';

const bookingUrl = import.meta.env.PUBLIC_GLOWFOX_CLASSES_URL;
const membershipUrl = import.meta.env.PUBLIC_GLOWFOX_MEMBERSHIPS_URL;

const neighborhoodName = "Brandon";
const pageSlug = "brandon";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thesaunaguys.com/" },
    { "@type": "ListItem", "position": 2, "name": `Sauna Near ${neighborhoodName}`, "item": `https://thesaunaguys.com/near/${pageSlug}` }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is it worth driving from Brandon for a sauna session?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our Brandon and Riverview members consistently tell us it's the best 20 minutes of their week. There's no dedicated contrast therapy studio east of the Crosstown, and our barrel sauna and cold plunge pools deliver a level of experience you simply can't find closer to home."
      }
    },
    {
      "@type": "Question",
      "name": "What route should I take from Brandon?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The fastest route is usually the Selmon Expressway (SR-618) heading west, which drops you right into the 22nd Street corridor. SR-60 (Adamo Drive) west is also direct. Both routes take about 20 minutes from the Brandon area."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need experience with cold plunge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not at all. Our guided sessions are designed specifically for beginners. A coach walks you through every step — from sauna breathing techniques to cold plunge entry. You control the pace and intensity the entire time."
      }
    },
    {
      "@type": "Question",
      "name": "What are the weekend hours?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We're open Saturday and Sunday from 8 AM to 6 PM. Many Brandon members make it a weekend ritual — drive in for a morning session, then grab lunch in Ybor or the Heights before heading home."
      }
    }
  ]
};
---

<PublicLayout
  title="Cold Plunge Near Brandon | The Sauna Guys Tampa"
  description="Cold plunge and sauna therapy 20 minutes from Brandon, Valrico, and Riverview. Tampa's top contrast therapy studio. Try 3 sessions for $60."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <HeroImage src="/images/cold-plunge.jpg" alt="Cold plunge therapy at The Sauna Guys near Brandon" height="medium">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Cold Plunge & Sauna — 20 Minutes from Brandon</h1>
    <p class="text-lg md:text-xl max-w-2xl mx-auto mb-8">
      Brandon, Valrico, and Riverview residents are making the short trip across the Crosstown for Tampa's only dedicated sauna and cold plunge studio. Once you feel the contrast, you'll understand why. New to contrast therapy? Check out our <a href="/first-visit" class="underline font-semibold">first visit guide</a>.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href={bookingUrl} variant="on-dark" target="_blank">Book a Session</Button>
      <Button href="#location" variant="outline">Get Directions</Button>
    </div>
  </HeroImage>

  <div class="accent-line"></div>

  <!-- Quick Facts -->
  <Section variant="warm" id="quick-facts">
    <div class="max-w-3xl mx-auto">
      <Card variant="clay" class="p-8">
        <h2 class="text-2xl font-bold mb-6 text-center">Getting Here from Brandon</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="flex items-start gap-3">
            <Icon name="clock" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">20-Minute Drive</p>
              <p class="text-gray-600 text-sm">Take the Selmon Expressway (SR-618) west or head west on SR-60 (Adamo Drive). Both routes bring you straight to the 22nd Street corridor in about 20 minutes.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <Icon name="map-pin" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">1703 N 24th Street</p>
              <p class="text-gray-600 text-sm">Conveniently situated right off I-4, between Ybor City and the Heights. Easy in, easy out.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <Icon name="compass" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">Free On-Site Parking</p>
              <p class="text-gray-600 text-sm">A dedicated free lot right at the studio. No paying for parking — ever. Just pull in and start your session.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <Icon name="calendar" size={24} class="text-teal shrink-0 mt-1" />
            <div>
              <p class="font-semibold">Weekend Sessions Available</p>
              <p class="text-gray-600 text-sm">Sat-Sun 8 AM - 6 PM. Turn your weekend errand run into Tampa into a recovery session while you're already out.</p>
            </div>
          </div>
        </div>
      </Card>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Why Choose Us -->
  <Section variant="light" id="why-choose-us">
    <SectionHeading title="Why Brandon Residents Make the Trip" subtitle="There's nothing like this east of the Crosstown. Here's why it's worth the drive." />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="snowflake" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Real Cold Plunge</h3>
        <p class="text-gray-600 text-sm">Not a cool bath or a chilly pool. Our cold plunge tubs are maintained at temperatures that trigger a genuine cold shock response for maximum benefit.</p>
      </Card>
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="thermometer-sun" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">190 F+ Barrel Sauna</h3>
        <p class="text-gray-600 text-sm">Finnish-style dry sauna that actually gets hot. Deep, penetrating heat that your gym sauna simply cannot match.</p>
      </Card>
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="heart-pulse" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Total-Body Recovery</h3>
        <p class="text-gray-600 text-sm">Pair your CrossFit, running, or gym routine in Brandon with proper contrast therapy. Heat and cold together accelerate muscle repair and reduce soreness.</p>
      </Card>
      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="star" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Worth the Drive</h3>
        <p class="text-gray-600 text-sm">Brandon, Valrico, and Riverview members consistently tell us the 20-minute trip is the best part of their week. Come find out why.</p>
      </Card>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Sessions Overview -->
  <Section variant="dark" id="sessions">
    <SectionHeading title="Pick Your Session" subtitle="Structured guidance or total freedom — your call, every visit" light />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <Card variant="dark" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="compass" size={36} class="text-teal" />
        </div>
        <h3 class="text-xl mb-2 text-white">1-Hour Guided</h3>
        <p class="text-white/70 text-sm mb-4">First time? Start here. A coach walks you through sauna rounds, breathwork, and your first cold plunge entry — step by step, at your comfort level.</p>
        <Button href="/services" variant="on-dark">Learn More</Button>
      </Card>
      <Card variant="dark" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="sun" size={36} class="text-teal" />
        </div>
        <h3 class="text-xl mb-2 text-white">1-Hour Open</h3>
        <p class="text-white/70 text-sm mb-4">Full facility access on your terms. Set your own timing, pick your plunge temp, and work through as many rounds as you want in 60 minutes.</p>
        <Button href="/services" variant="on-dark">Learn More</Button>
      </Card>
      <Card variant="dark" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="users" size={36} class="text-teal" />
        </div>
        <h3 class="text-xl mb-2 text-white">Women's Group</h3>
        <p class="text-white/70 text-sm mb-4">A guided session in a private, women-only setting. A supportive space to challenge yourself and connect with a growing Tampa wellness community.</p>
        <Button href="/services" variant="on-dark">Learn More</Button>
      </Card>
    </div>
    <p class="text-center mt-6 text-white/60">
      First time? Read our <a href="/first-visit" class="text-teal underline hover:text-white transition-colors">complete first visit guide</a> to know exactly what to expect.
    </p>
  </Section>

  <div class="accent-line"></div>

  <!-- Pricing CTA -->
  <Section variant="warm" id="intro-offer">
    <div class="max-w-xl mx-auto text-center">
      <Card variant="gold" class="p-8 relative">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-dark-teal text-white text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full whitespace-nowrap">
          Best for First-Timers
        </span>
        <div class="flex justify-center mb-3">
          <Icon name="gift" size={36} class="text-dark-teal" />
        </div>
        <h2 class="text-2xl font-bold mb-2">The Sauna Sampler</h2>
        <p class="text-5xl font-bold text-dark-teal mb-2">$60</p>
        <p class="text-black/70 mb-1">3 sessions to try us out</p>
        <p class="text-black/60 text-sm mb-6">Three visits to experience what contrast therapy feels like. That's three round trips from Brandon — and we promise the third one won't feel long enough.</p>
        <Button href={membershipUrl} variant="secondary" target="_blank">Get the Sampler</Button>
      </Card>
    </div>
  </Section>

  <!-- FAQ -->
  <div class="accent-line"></div>
  <Section variant="light" id="faq">
    <SectionHeading title="Frequently Asked Questions" subtitle="Common questions from Brandon visitors" />
    <div class="max-w-3xl mx-auto space-y-4">
      <details class="group" open>
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>Is it worth driving from Brandon for a sauna session?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>Our Brandon and Riverview members consistently tell us it's the best 20 minutes of their week. There's no dedicated contrast therapy studio east of the Crosstown, and our barrel sauna and cold plunge pools deliver a level of experience you simply can't find closer to home.</p>
        </div>
      </details>
      <details class="group">
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>What route should I take from Brandon?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>The fastest route is usually the Selmon Expressway (SR-618) heading west, which drops you right into the 22nd Street corridor. SR-60 (Adamo Drive) west is also direct. Both routes take about 20 minutes from the Brandon area.</p>
        </div>
      </details>
      <details class="group">
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>Do I need experience with cold plunge?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>Not at all. Our guided sessions are designed specifically for beginners. A coach walks you through every step — from sauna breathing techniques to cold plunge entry. You control the pace and intensity the entire time.</p>
        </div>
      </details>
      <details class="group">
        <summary class="flex items-center justify-between cursor-pointer p-4 bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-clay)] border border-black/[0.04] font-semibold text-dark-teal">
          <span>What are the weekend hours?</span>
          <Icon name="chevron-down" size={20} class="text-teal transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-4 pb-4 pt-2 text-gray-600">
          <p>We're open Saturday and Sunday from 8 AM to 6 PM. Many Brandon members make it a weekend ritual — drive in for a morning session, then grab lunch in Ybor or the Heights before heading home.</p>
        </div>
      </details>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Google Maps -->
  <Section variant="light" id="location">
    <SectionHeading title="Find Us from Brandon" subtitle="Selmon Expressway west or SR-60 — straight to our door in about 20 minutes" />
    <div class="rounded-[var(--radius-card)] overflow-hidden shadow-lg">
      <iframe
        src="https://maps.google.com/maps?q=1703+N+24th+St,+Tampa,+FL+33605&t=&z=13&ie=UTF8&iwloc=&output=embed"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Map showing The Sauna Guys location near Brandon and Valrico"
      ></iframe>
    </div>
    <div class="mt-6 text-center">
      <p class="text-gray-600 mb-2">
        <Icon name="map-pin" size={18} class="inline text-teal" /> 1703 North 24th Street, Tampa, FL 33605
      </p>
      <p class="text-gray-600 mb-2">
        <Icon name="phone" size={18} class="inline text-teal" /> <a href="tel:8135514177" class="text-teal hover:underline">(813) 551-4177</a>
      </p>
      <p class="text-gray-600">
        <Icon name="mail" size={18} class="inline text-teal" /> <a href="mailto:hello@thesaunaguys.com" class="text-teal hover:underline">hello@thesaunaguys.com</a>
      </p>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Nearby Neighborhoods -->
  <Section variant="teal" id="nearby">
    <SectionHeading title="Explore More Neighborhoods" subtitle="We're accessible from all over the greater Tampa Bay area" />
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 max-w-4xl mx-auto">
      <a href="/near/south-tampa" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">South Tampa</p>
        <p class="text-xs text-gray-600">10 min drive</p>
      </a>
      <a href="/near/downtown-tampa" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Downtown Tampa</p>
        <p class="text-xs text-gray-600">8 min drive</p>
      </a>
      <a href="/near/ybor-city" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Ybor City</p>
        <p class="text-xs text-gray-600">7 min drive</p>
      </a>
      <a href="/near/seminole-heights" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Seminole Heights</p>
        <p class="text-xs text-gray-600">10 min drive</p>
      </a>
      <a href="/near/westchase" class="text-center p-3 rounded-lg bg-white/60 hover:bg-white transition-colors">
        <p class="font-semibold text-sm">Westchase</p>
        <p class="text-xs text-gray-600">15 min drive</p>
      </a>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Bottom CTA -->
  <Section variant="dark" id="book-now">
    <div class="text-center">
      <SectionHeading
        title="Brandon's Best Recovery Is 20 Minutes Away"
        subtitle="No contrast therapy studio in Brandon? No problem. We built one worth the drive. Book your first session and feel the difference."
        light
      />
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={bookingUrl} variant="on-dark" target="_blank">Book a Session</Button>
        <Button href={membershipUrl} variant="outline" target="_blank">View Memberships</Button>
      </div>
    </div>
  </Section>
</PublicLayout>
