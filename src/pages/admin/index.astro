---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { createSupabaseServerClient } from '../../lib/supabase';
import type { Member, ActivityLogEntry } from '../../lib/types';
import { formatCents } from '../../lib/types';
import TierChart from '../../components/admin/TierChart';
import ActivityFeed from '../../components/admin/ActivityFeed';

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request.headers);

// ── 1. Member counts by status group ──
const { count: activeCount } = await supabase
  .from('members')
  .select('*', { count: 'exact', head: true })
  .in('current_tier_number', [0, 1]);

const { count: atRiskCount } = await supabase
  .from('members')
  .select('*', { count: 'exact', head: true })
  .in('current_tier_number', [2, 3, 4, 5]);

const { count: totalCount } = await supabase
  .from('members')
  .select('*', { count: 'exact', head: true });

const { count: reactivatedCount } = await supabase
  .from('members')
  .select('*', { count: 'exact', head: true })
  .eq('is_reactivated', true);

// ── 2. Tier distribution data ──
const { data: allMembers } = await supabase
  .from('members')
  .select('current_tier_number, estimated_ltv');

const tierLabels: Record<number, string> = {
  0: 'Active (0/0B)',
  1: 'Warm (1/1B)',
  2: 'Proven Buyer',
  3: 'Moderate Buyer',
  4: 'Trial Convert',
  5: 'Credits Ice Cold',
  6: 'Dark (6/6B)',
  7: 'One-and-Done (7A-C)',
  8: 'No-Show',
  9: 'Ghost Signup',
};

// Aggregate tier distribution from member rows
const tierMap = new Map<number, { count: number; ltv: number }>();
for (const m of allMembers ?? []) {
  const tier = m.current_tier_number ?? 9;
  const entry = tierMap.get(tier) ?? { count: 0, ltv: 0 };
  entry.count += 1;
  entry.ltv += m.estimated_ltv ?? 0;
  tierMap.set(tier, entry);
}

const tierData = Array.from(tierMap.entries())
  .sort(([a], [b]) => a - b)
  .map(([tier, stats]) => ({
    tier,
    label: tierLabels[tier] ?? `Tier ${tier}`,
    count: stats.count,
    ltv: stats.ltv,
  }));

// ── 3. Recent activity ──
const { data: recentActivity } = await supabase
  .from('activity_log')
  .select('*')
  .order('created_at', { ascending: false })
  .limit(10);

const activities: ActivityLogEntry[] = recentActivity ?? [];

// ── 4. Monthly revenue estimate (recurring tier-0 members) ──
const { data: revenueMembers } = await supabase
  .from('members')
  .select('estimated_ltv, membership_plan')
  .eq('current_tier_number', 0);

let monthlyRevenue = 0;
for (const m of revenueMembers ?? []) {
  // Include members on recurring plans for monthly revenue estimate
  const plan = (m.membership_plan ?? '').toLowerCase();
  if (plan.includes('month') || plan.includes('recurring') || plan.includes('unlimited') || plan.includes('membership')) {
    monthlyRevenue += m.estimated_ltv ?? 0;
  }
}

// ── 5. Average tier score ──
let avgTier = 0;
if (allMembers && allMembers.length > 0) {
  const sum = allMembers.reduce((acc, m) => acc + (m.current_tier_number ?? 9), 0);
  avgTier = sum / allMembers.length;
}

// ── 6. Top 10 members for preview table ──
const { data: topMembers } = await supabase
  .from('members')
  .select('id, first_name, last_name, email, current_tier, current_tier_number, estimated_ltv, credits_remaining, last_booking')
  .order('current_tier_number', { ascending: true })
  .order('last_name', { ascending: true })
  .limit(10);

const members: Partial<Member>[] = topMembers ?? [];

// Format today's date
const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<AdminLayout title="Overview" activeNav="overview">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900" style="font-family: var(--font-heading);">Overview</h1>
    <p class="text-sm text-gray-500 mt-1">{today}</p>
  </div>

  <!-- Stat Cards Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <!-- Active Members -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between mb-1">
        <p class="text-sm text-gray-500">Active Members</p>
        <div class="w-8 h-8 rounded-lg bg-teal/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-bold font-mono text-gray-900">{activeCount ?? 0}</p>
      <p class="text-xs text-teal mt-1">of {totalCount ?? 0} total members</p>
    </div>

    <!-- At Risk -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between mb-1">
        <p class="text-sm text-gray-500">At Risk</p>
        <div class="w-8 h-8 rounded-lg bg-orange-50 flex items-center justify-center">
          <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-bold font-mono text-gray-900">{atRiskCount ?? 0}</p>
      <p class="text-xs text-orange-500 mt-1">{reactivatedCount ?? 0} reactivated</p>
    </div>

    <!-- Monthly Revenue -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between mb-1">
        <p class="text-sm text-gray-500">Monthly Revenue</p>
        <div class="w-8 h-8 rounded-lg bg-green-50 flex items-center justify-center">
          <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-bold font-mono text-gray-900">{formatCents(monthlyRevenue)}</p>
      <p class="text-xs text-green-600 mt-1">est. recurring revenue</p>
    </div>

    <!-- Avg Tier Score -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between mb-1">
        <p class="text-sm text-gray-500">Avg Tier Score</p>
        <div class="w-8 h-8 rounded-lg bg-purple-50 flex items-center justify-center">
          <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-bold font-mono text-gray-900">{avgTier.toFixed(1)}</p>
      <p class="text-xs text-purple-600 mt-1">lower is better (0 = best)</p>
    </div>
  </div>

  <!-- Tier Distribution Chart -->
  <div class="bg-white rounded-xl shadow-sm p-6 mb-8">
    <h2 class="text-lg font-bold text-gray-900 mb-4" style="font-family: var(--font-heading);">Tier Distribution</h2>
    <TierChart client:only="react" data={tierData} mode="bar" />
  </div>

  <!-- Two Column Layout: Members Preview + Activity Feed -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Members Preview (2/3) -->
    <div class="lg:col-span-2 bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900" style="font-family: var(--font-heading);">Members</h2>
        <a href="/admin/members" class="text-sm text-teal hover:text-dark-teal font-medium transition-colors">
          View all &rarr;
        </a>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left py-2 px-3 text-xs font-medium text-gray-400 uppercase tracking-wider">Name</th>
              <th class="text-left py-2 px-3 text-xs font-medium text-gray-400 uppercase tracking-wider">Tier</th>
              <th class="text-right py-2 px-3 text-xs font-medium text-gray-400 uppercase tracking-wider">LTV</th>
              <th class="text-right py-2 px-3 text-xs font-medium text-gray-400 uppercase tracking-wider">Credits</th>
              <th class="text-left py-2 px-3 text-xs font-medium text-gray-400 uppercase tracking-wider">Last Booking</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            {members.map((m) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-2.5 px-3">
                  <a href={`/admin/members/${m.id}`} class="text-gray-900 font-medium hover:text-teal transition-colors">
                    {m.first_name} {m.last_name}
                  </a>
                  <p class="text-xs text-gray-400 truncate max-w-[200px]">{m.email}</p>
                </td>
                <td class="py-2.5 px-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
                    {m.current_tier ?? 'Unknown'}
                  </span>
                </td>
                <td class="py-2.5 px-3 text-right font-mono text-gray-700">
                  {formatCents(m.estimated_ltv ?? 0)}
                </td>
                <td class="py-2.5 px-3 text-right font-mono text-gray-700">
                  {m.credits_remaining ?? 0}
                </td>
                <td class="py-2.5 px-3 text-gray-500 text-xs">
                  {m.last_booking
                    ? new Date(m.last_booking).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
                    : '—'}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {members.length === 0 && (
        <p class="text-center text-gray-400 py-8 text-sm">No members found. Import your first CSV to get started.</p>
      )}
    </div>

    <!-- Activity Feed (1/3) -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4" style="font-family: var(--font-heading);">Recent Activity</h2>
      <ActivityFeed client:only="react" activities={activities} />
      {activities.length === 0 && (
        <p class="text-center text-gray-400 py-8 text-sm">No recent activity.</p>
      )}
    </div>
  </div>
</AdminLayout>
