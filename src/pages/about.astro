---
import PublicLayout from '../layouts/PublicLayout.astro';
---

<PublicLayout
  title="About Us | The Sauna Guys"
  description="Meet the team behind Tampa's favorite sauna and cold plunge studio. Our story, mission, and commitment to wellness."
>
  <!-- Hero -->
  <section class="section-dark py-24">
    <div class="container text-center">
      <h1 class="text-white">About The Sauna Guys</h1>
    </div>
  </section>

  <div class="accent-line"></div>

  <!-- Our Story -->
  <section class="section-light py-20">
    <div class="container max-w-3xl mx-auto">
      <h2 class="text-center mb-8">Our Story</h2>
      <div class="prose prose-lg mx-auto text-gray-600 space-y-6">
        <p>
          What started as a passion for Finnish sauna culture and cold water immersion turned into Tampa's go-to spot for contrast therapy. The Sauna Guys was born from a simple idea: everyone deserves access to the recovery and wellness benefits that hot-cold therapy provides.
        </p>
        <p>
          Located in the heart of South Tampa, we've built a welcoming space where anyone — from elite athletes to stressed-out professionals to curious first-timers — can experience the transformative power of heat and cold.
        </p>
        <p>
          Our guided sessions take the guesswork out of contrast therapy. Whether it's your first time or your hundredth, our team is here to make sure you get the most out of every visit.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="section-dark py-20">
    <div class="container text-center max-w-3xl mx-auto">
      <h2 class="text-white mb-8">Our Mission</h2>
      <p class="text-white/80 text-xl leading-relaxed">
        To make the science-backed benefits of sauna and cold plunge accessible, enjoyable, and part of Tampa's wellness routine. We believe recovery isn't a luxury — it's a necessity.
      </p>
    </div>
  </section>

  <div class="accent-line"></div>

  <!-- Values -->
  <section class="section-light py-20">
    <div class="container">
      <h2 class="text-center mb-12">What We Stand For</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="w-16 h-16 bg-teal/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-teal text-2xl">🔬</span>
          </div>
          <h3 class="text-xl mb-3">Science-Backed</h3>
          <p class="text-gray-600">Every protocol and recommendation is grounded in peer-reviewed research. No fads, no gimmicks.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-teal/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-teal text-2xl">🤝</span>
          </div>
          <h3 class="text-xl mb-3">Community First</h3>
          <p class="text-gray-600">We're building more than a studio — we're building a community of people who prioritize their wellbeing.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-teal/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-teal text-2xl">🌊</span>
          </div>
          <h3 class="text-xl mb-3">Accessible Wellness</h3>
          <p class="text-gray-600">Recovery shouldn't be exclusive. We offer flexible pricing so everyone can benefit from contrast therapy.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Placeholder -->
  <section class="section-dark py-20">
    <div class="container text-center">
      <h2 class="text-white mb-8">Meet the Team</h2>
      <p class="text-white/70 max-w-2xl mx-auto mb-12">
        Our class leaders are certified in sauna protocols, cold exposure, and breathwork techniques.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <!-- Team member cards will be populated with actual team data -->
        <div class="text-center">
          <div class="w-32 h-32 bg-gold rounded-full mx-auto mb-4 flex items-center justify-center">
            <span class="text-4xl">🧖</span>
          </div>
          <h3 class="text-white text-xl mb-1">Team Member</h3>
          <p class="text-teal text-sm uppercase tracking-wider">Class Leader</p>
        </div>
        <div class="text-center">
          <div class="w-32 h-32 bg-gold rounded-full mx-auto mb-4 flex items-center justify-center">
            <span class="text-4xl">🧖</span>
          </div>
          <h3 class="text-white text-xl mb-1">Team Member</h3>
          <p class="text-teal text-sm uppercase tracking-wider">Class Leader</p>
        </div>
        <div class="text-center">
          <div class="w-32 h-32 bg-gold rounded-full mx-auto mb-4 flex items-center justify-center">
            <span class="text-4xl">🧖</span>
          </div>
          <h3 class="text-white text-xl mb-1">Team Member</h3>
          <p class="text-teal text-sm uppercase tracking-wider">Class Leader</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="accent-line"></div>
  <section class="bg-teal py-16">
    <div class="container text-center">
      <h2 class="text-black mb-4">Ready to Experience It?</h2>
      <p class="text-black/70 text-lg max-w-xl mx-auto mb-8">
        Try the Sauna Sampler — 3 guided sessions for $60. No commitment, just great recovery.
      </p>
      <a
        href={import.meta.env.PUBLIC_GLOWFOX_MEMBERSHIPS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-10 py-4 bg-dark-teal text-white font-bold uppercase tracking-wider rounded-[60px] hover:bg-dark-teal/90 transition-all duration-200"
      >
        Try 3 Sessions for $60
      </a>
    </div>
  </section>
</PublicLayout>
