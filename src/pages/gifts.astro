---
import PublicLayout from '../layouts/PublicLayout.astro';
import HeroImage from '../components/ui/HeroImage.astro';
import Section from '../components/ui/Section.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Card from '../components/ui/Card.astro';
import Icon from '../components/ui/Icon.astro';
import Button from '../components/ui/Button.astro';

const glowfoxMembershipsUrl = import.meta.env.PUBLIC_GLOWFOX_MEMBERSHIPS_URL;

const giftTiers = [
  {
    name: 'Single Session',
    price: '$39',
    description: 'One full sauna and cold plunge session. Perfect for a friend who is curious about contrast therapy.',
    highlight: false,
  },
  {
    name: 'Sauna Sampler',
    price: '$60',
    description: 'Three sessions to explore at their own pace. Our most popular gift — and the best way to get hooked.',
    highlight: true,
  },
  {
    name: 'Monthly Membership',
    price: '$120 – $180',
    description: 'A full month of unlimited sessions. The ultimate wellness gift for someone who deserves real recovery.',
    highlight: false,
  },
  {
    name: 'Custom Amount',
    price: 'You Choose',
    description: 'Pick any dollar amount and let them decide how to use it — sessions, packs, or membership credit.',
    highlight: false,
  },
];

const howItWorks = [
  {
    step: '01',
    title: 'Choose',
    description: 'Pick a gift tier or set a custom amount that fits your budget.',
  },
  {
    step: '02',
    title: 'Personalize',
    description: 'Add a personal message and the recipient details. Make it special.',
  },
  {
    step: '03',
    title: 'Deliver',
    description: 'Send it instantly via email or print it out for an in-person surprise.',
  },
];
---

<PublicLayout
  title="Gift Cards | The Sauna Guys"
  description="Give the gift of wellness. Sauna and cold plunge gift cards for any occasion. Instant delivery available."
>
  <!-- Hero -->
  <HeroImage src="/images/woman-sauna.jpg" alt="Sauna experience" height="short">
    <h1>Give the Gift of Recovery</h1>
    <p class="text-lg max-w-2xl mx-auto">
      Birthdays, holidays, or just because. A sauna and cold plunge gift card is the wellness experience they will not buy for themselves — but absolutely deserve.
    </p>
  </HeroImage>

  <div class="accent-line"></div>

  <!-- Gift Tiers -->
  <Section variant="warm">
    <SectionHeading title="Gift Options" />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 max-w-5xl mx-auto">
      {giftTiers.map((tier) => (
        <Card variant={tier.highlight ? 'gold' : 'clay'} class="p-8 text-center flex flex-col">
          {tier.highlight && (
            <span class="inline-block bg-dark-teal text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-4 self-center">
              Most Popular
            </span>
          )}
          <Icon name="gift" size={28} class={`mx-auto mb-3 ${tier.highlight ? 'text-dark-teal' : 'text-teal'}`} />
          <h3 class="text-xl mb-2">{tier.name}</h3>
          <div class="text-3xl font-bold text-dark-teal mb-4">{tier.price}</div>
          <p class={`text-sm flex-grow ${tier.highlight ? 'text-dark-teal/80' : 'text-gray-600'}`}>{tier.description}</p>
        </Card>
      ))}
    </div>

    <div class="text-center mt-12">
      <Button href={glowfoxMembershipsUrl} variant="primary" target="_blank">
        Purchase a Gift Card
      </Button>
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- How It Works -->
  <Section variant="dark">
    <SectionHeading title="How It Works" light />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      {howItWorks.map((item) => (
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-teal flex items-center justify-center mx-auto mb-4">
            <span class="text-black font-bold text-xl">{item.step}</span>
          </div>
          <h3 class="text-xl text-white mb-2">{item.title}</h3>
          <p class="text-white/70">{item.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <div class="accent-line"></div>

  <!-- Occasions -->
  <Section variant="light">
    <div class="max-w-3xl mx-auto text-center">
      <SectionHeading title="Perfect For Any Occasion" />
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {['Birthdays', 'Holidays', 'Father\'s Day', 'Mother\'s Day', 'Valentine\'s Day', 'Thank You', 'Corporate Gifts', 'Just Because'].map((occasion) => (
          <Card variant="clay" class="px-5 py-2 inline-block">
            <span class="text-dark-teal font-bold text-sm">{occasion}</span>
          </Card>
        ))}
      </div>
      <p class="text-gray-600 text-lg mb-8">
        Gift cards never expire. Recipients can book online anytime and choose the session that works for them.
      </p>
      <Button href={glowfoxMembershipsUrl} variant="primary" target="_blank">
        Buy a Gift Card Now
      </Button>
    </div>
  </Section>
</PublicLayout>
