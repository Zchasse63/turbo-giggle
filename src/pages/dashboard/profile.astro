---
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { createSupabaseServerClient } from '../../lib/supabase';
import type { Profile } from '../../lib/types';

const user = Astro.locals.user;
const profile = Astro.locals.profile;
const supabase = createSupabaseServerClient(Astro.cookies, Astro.request.headers);

// Handle profile update
let updateSuccess = false;
let updateError = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const full_name = formData.get('full_name')?.toString() || null;
  const phone = formData.get('phone')?.toString() || null;

  const { error } = await supabase
    .from('profiles')
    .update({ full_name, phone, updated_at: new Date().toISOString() })
    .eq('id', user.id);

  if (error) {
    updateError = error.message;
  } else {
    updateSuccess = true;
    // Refresh profile data
    profile.full_name = full_name;
    profile.phone = phone;
  }
}

// Get full profile data
const { data: fullProfile } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', user.id)
  .single();
---

<DashboardLayout title="Profile | The Sauna Guys" activeNav="profile">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">My Profile</h1>
    <p class="text-gray-500 text-sm mt-1">Update your information</p>
  </div>

  <div class="max-w-lg">
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      {updateSuccess && (
        <div class="mb-6 p-3 rounded-lg bg-green-50 border border-green-200 text-green-700 text-sm">
          Profile updated successfully.
        </div>
      )}

      {updateError && (
        <div class="mb-6 p-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">
          {updateError}
        </div>
      )}

      <form method="POST" class="space-y-5">
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            Email
          </label>
          <input
            type="email"
            id="email"
            value={user.email}
            disabled
            class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 text-gray-500 cursor-not-allowed"
          />
          <p class="text-xs text-gray-400 mt-1">Contact a manager to change your email.</p>
        </div>

        <div>
          <label for="full_name" class="block text-sm font-medium text-gray-700 mb-1">
            Full Name
          </label>
          <input
            type="text"
            id="full_name"
            name="full_name"
            value={fullProfile?.full_name || ''}
            class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent"
            placeholder="Your full name"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
            Phone
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            value={fullProfile?.phone || ''}
            class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent"
            placeholder="(813) 555-1234"
          />
        </div>

        <button
          type="submit"
          class="w-full py-3 px-4 bg-teal text-white font-bold rounded-xl hover:bg-dark-teal transition-colors duration-200 cursor-pointer"
        >
          Save Changes
        </button>
      </form>
    </div>

    <!-- Account Info (read-only) -->
    <div class="bg-white rounded-xl border border-gray-200 p-6 mt-6">
      <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400 mb-4">Account Info</h3>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">Role</dt>
          <dd class="font-medium text-gray-900 capitalize">{fullProfile?.role || 'employee'}</dd>
        </div>
        {fullProfile?.hire_date && (
          <div class="flex justify-between">
            <dt class="text-gray-500">Hire Date</dt>
            <dd class="font-medium text-gray-900">
              {new Date(fullProfile.hire_date + 'T00:00:00').toLocaleDateString('en-US', {
                month: 'long',
                day: 'numeric',
                year: 'numeric',
              })}
            </dd>
          </div>
        )}
        <div class="flex justify-between">
          <dt class="text-gray-500">Account Status</dt>
          <dd class={`font-medium ${fullProfile?.is_active ? 'text-green-600' : 'text-red-600'}`}>
            {fullProfile?.is_active ? 'Active' : 'Inactive'}
          </dd>
        </div>
      </dl>
    </div>
  </div>
</DashboardLayout>
