---
export const prerender = false;

import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase';
import type { HourLog, Profile, ApprovalStatus } from '../../../lib/types';

const user = Astro.locals.user;
const supabase = createSupabaseServerClient(Astro.cookies, Astro.request.headers);

// Handle approval/rejection
let actionMessage = '';
let actionError = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const logId = formData.get('log_id')?.toString();
  const action = formData.get('action')?.toString() as 'approved' | 'rejected';

  if (logId && (action === 'approved' || action === 'rejected')) {
    const { error } = await supabase
      .from('hour_logs')
      .update({
        approval_status: action,
        approved_by: user.id,
        approved_at: new Date().toISOString(),
      })
      .eq('id', logId);

    if (error) {
      actionError = error.message;
    } else {
      actionMessage = `Entry ${action} successfully.`;
    }
  }
}

// Fetch pending hour logs with employee info
const { data: pendingLogs } = await supabase
  .from('hour_logs')
  .select(`
    *,
    profiles:employee_id (
      full_name,
      email
    )
  `)
  .eq('approval_status', 'pending')
  .order('shift_date', { ascending: false });

// Fetch recently reviewed (last 7 days)
const weekAgo = new Date();
weekAgo.setDate(weekAgo.getDate() - 7);
const { data: recentLogs } = await supabase
  .from('hour_logs')
  .select(`
    *,
    profiles:employee_id (
      full_name,
      email
    )
  `)
  .neq('approval_status', 'pending')
  .gte('approved_at', weekAgo.toISOString())
  .order('approved_at', { ascending: false })
  .limit(20);

function formatTime(isoString: string | null): string {
  if (!isoString) return '—';
  return new Date(isoString).toLocaleTimeString('en-US', {
    hour: 'numeric',
    minute: '2-digit',
  });
}

function formatDate(dateStr: string): string {
  return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', {
    weekday: 'short',
    month: 'short',
    day: 'numeric',
  });
}

function getEmployeeName(log: any): string {
  return log.profiles?.full_name || log.profiles?.email || 'Unknown';
}
---

<DashboardLayout title="Approvals | The Sauna Guys" activeNav="approvals">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Hour Approvals</h1>
    <p class="text-gray-500 text-sm mt-1">
      {(pendingLogs || []).length} pending approval{(pendingLogs || []).length !== 1 ? 's' : ''}
    </p>
  </div>

  {actionMessage && (
    <div class="mb-6 p-3 rounded-lg bg-green-50 border border-green-200 text-green-700 text-sm">
      {actionMessage}
    </div>
  )}

  {actionError && (
    <div class="mb-6 p-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">
      {actionError}
    </div>
  )}

  <!-- Pending Approvals -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden mb-8">
    <div class="px-4 py-3 border-b border-gray-200 bg-gray-50">
      <h3 class="text-sm font-bold uppercase tracking-wider text-gray-500">Pending</h3>
    </div>

    {(pendingLogs || []).length > 0 ? (
      <div class="divide-y divide-gray-100">
        {(pendingLogs || []).map((log: any) => (
          <div class="p-4 flex flex-col sm:flex-row sm:items-center gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-1">
                <div class="w-8 h-8 rounded-full bg-teal/20 flex items-center justify-center text-teal font-bold text-xs">
                  {getEmployeeName(log).charAt(0).toUpperCase()}
                </div>
                <div>
                  <p class="font-medium text-gray-900 text-sm">{getEmployeeName(log)}</p>
                  <p class="text-xs text-gray-400">{formatDate(log.shift_date)}</p>
                </div>
              </div>
              <div class="flex gap-4 text-sm text-gray-600 ml-11">
                <span>In: {formatTime(log.clock_in)}</span>
                <span>Out: {formatTime(log.clock_out)}</span>
                <span class="font-medium">
                  {log.hours_worked ? `${log.hours_worked.toFixed(1)} hrs` : 'In progress'}
                </span>
                {log.break_minutes > 0 && (
                  <span>Break: {log.break_minutes}m</span>
                )}
              </div>
              {log.notes && (
                <p class="text-xs text-gray-400 ml-11 mt-1">Note: {log.notes}</p>
              )}
            </div>

            <div class="flex gap-2 ml-11 sm:ml-0">
              <form method="POST" class="inline">
                <input type="hidden" name="log_id" value={log.id} />
                <input type="hidden" name="action" value="approved" />
                <button
                  type="submit"
                  class="px-4 py-2 bg-green-500 text-white text-xs font-bold rounded-lg hover:bg-green-600 transition-colors cursor-pointer"
                >
                  Approve
                </button>
              </form>
              <form method="POST" class="inline">
                <input type="hidden" name="log_id" value={log.id} />
                <input type="hidden" name="action" value="rejected" />
                <button
                  type="submit"
                  class="px-4 py-2 bg-red-500 text-white text-xs font-bold rounded-lg hover:bg-red-600 transition-colors cursor-pointer"
                >
                  Reject
                </button>
              </form>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="p-12 text-center">
        <p class="text-gray-400">No pending approvals. All caught up!</p>
      </div>
    )}
  </div>

  <!-- Recent Activity -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-200 bg-gray-50">
      <h3 class="text-sm font-bold uppercase tracking-wider text-gray-500">Recently Reviewed (7 days)</h3>
    </div>

    {(recentLogs || []).length > 0 ? (
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left px-4 py-2 text-xs font-bold uppercase tracking-wider text-gray-400">Employee</th>
              <th class="text-left px-4 py-2 text-xs font-bold uppercase tracking-wider text-gray-400">Date</th>
              <th class="text-left px-4 py-2 text-xs font-bold uppercase tracking-wider text-gray-400">Hours</th>
              <th class="text-left px-4 py-2 text-xs font-bold uppercase tracking-wider text-gray-400">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            {(recentLogs || []).map((log: any) => (
              <tr>
                <td class="px-4 py-2 text-gray-900">{getEmployeeName(log)}</td>
                <td class="px-4 py-2 text-gray-600">{formatDate(log.shift_date)}</td>
                <td class="px-4 py-2 text-gray-600">{log.hours_worked ? log.hours_worked.toFixed(1) : '—'}</td>
                <td class="px-4 py-2">
                  <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium capitalize ${
                    log.approval_status === 'approved'
                      ? 'bg-green-100 text-green-700'
                      : 'bg-red-100 text-red-700'
                  }`}>
                    {log.approval_status}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="p-8 text-center">
        <p class="text-gray-400 text-sm">No recent reviews.</p>
      </div>
    )}
  </div>
</DashboardLayout>
