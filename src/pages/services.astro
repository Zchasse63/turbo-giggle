---
import PublicLayout from '../layouts/PublicLayout.astro';
import { supabase } from '../lib/supabase';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
import Card from '../components/ui/Card.astro';
import Section from '../components/ui/Section.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import HeroImage from '../components/ui/HeroImage.astro';

const classesUrl = import.meta.env.PUBLIC_GLOWFOX_CLASSES_URL;
const membershipsUrl = import.meta.env.PUBLIC_GLOWFOX_MEMBERSHIPS_URL;

// Fetch pricing plans from Supabase
const { data: plans } = await supabase
  .from('pricing_plans')
  .select('*')
  .eq('is_active', true)
  .order('sort_order', { ascending: true });

// Group plans by category
const dropIns = plans?.filter(p => p.category === 'drop_in') ?? [];
const packs = plans?.filter(p => p.category === 'class_pack') ?? [];
const memberships = plans?.filter(p => p.category === 'membership') ?? [];
const intros = plans?.filter(p => p.category === 'sampler') ?? [];

function formatPrice(cents: number): string {
  return `$${(cents / 100).toFixed(0)}`;
}
---

<PublicLayout
  title="Services & Pricing | The Sauna Guys"
  description="Explore our sauna, cold plunge, and contrast therapy sessions. View pricing for memberships, class packs, and drop-in visits in Tampa."
>
  <!-- Hero -->
  <HeroImage src="/images/exterior.jpg" alt="The Sauna Guys studio exterior" height="short">
    <h1 class="mb-4">Our Services</h1>
    <p class="text-lg max-w-2xl mx-auto">
      Sauna, cold plunge, and contrast therapy sessions designed for every experience level. Choose the session that fits your goals.
    </p>
  </HeroImage>

  <div class="accent-line"></div>

  <!-- Session Types -->
  <Section variant="warm" id="sessions">
    <SectionHeading title="Our Sessions" subtitle="From guided coaching to self-directed sessions, find your rhythm" />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Guided Session — Flagship -->
      <Card variant="gold" class="p-8">
        <div class="flex justify-center mb-4">
          <Icon name="compass" size={40} class="text-dark-teal" />
        </div>
        <h3 class="text-2xl mb-3">1-Hour Guided</h3>
        <p class="text-black/70 mb-4">Our flagship experience. Expert-led rounds with breathwork coaching and cold plunge guidance.</p>
        <ul class="text-left space-y-2 mb-6">
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-dark-teal" /></span>
            <span>Instructor-led sauna rounds</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-dark-teal" /></span>
            <span>Guided cold plunge coaching</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-dark-teal" /></span>
            <span>Breathwork techniques</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-dark-teal" /></span>
            <span>Recovery cool-down</span>
          </li>
        </ul>
        <p class="text-sm text-black/60 mb-6"><strong>Best for:</strong> First-timers and anyone wanting structure</p>
        <Button href={classesUrl} variant="primary" target="_blank">Book Guided</Button>
      </Card>

      <!-- Open Session -->
      <Card variant="clay" class="p-8">
        <div class="flex justify-center mb-4">
          <Icon name="sun" size={40} class="text-teal" />
        </div>
        <h3 class="text-2xl mb-3 text-center">1-Hour Open</h3>
        <p class="text-gray-600 text-center mb-4">Full facility access at your own pace. Set your own rounds, timing, and intensity.</p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-teal" /></span>
            <span>Full facility access</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-teal" /></span>
            <span>Go at your own pace</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-teal" /></span>
            <span>Choose your rounds and timing</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-teal" /></span>
            <span>Self-directed experience</span>
          </li>
        </ul>
        <p class="text-sm text-gray-500 mb-6 text-center"><strong>Best for:</strong> Experienced plungers and regulars</p>
        <div class="text-center">
          <Button href={classesUrl} variant="primary" target="_blank">Book Open</Button>
        </div>
      </Card>

      <!-- Women's Group -->
      <Card variant="clay" class="p-8">
        <div class="flex justify-center mb-4">
          <Icon name="users" size={40} class="text-teal" />
        </div>
        <h3 class="text-2xl mb-3 text-center">Women's Group</h3>
        <p class="text-gray-600 text-center mb-4">A guided session in a women-only environment. Welcoming, supportive, and empowering.</p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-teal" /></span>
            <span>Women-only environment</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-teal" /></span>
            <span>Guided experience</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-teal" /></span>
            <span>Supportive community</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 shrink-0"><Icon name="check" size={18} class="text-teal" /></span>
            <span>Same great facilities</span>
          </li>
        </ul>
        <p class="text-sm text-gray-500 mb-6 text-center"><strong>Best for:</strong> Women wanting a private setting</p>
        <div class="text-center">
          <Button href={classesUrl} variant="primary" target="_blank">Book Women's</Button>
        </div>
      </Card>

    </div>
  </Section>

  <!-- Pricing Cards -->
  <Section variant="dark" id="pricing">
    <SectionHeading
      title="Pricing"
      subtitle="Flexible options from a single drop-in to unlimited monthly access"
      light
    />

    {/* Intro Offer - Highlighted */}
    {intros.length > 0 && (
      <div class="max-w-md mx-auto mb-12">
        {intros.map((plan) => (
          <Card variant="gold" class="p-8 relative">
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-dark-teal text-white text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full whitespace-nowrap">
              Best for First-Timers
            </span>
            <div class="flex justify-center mb-3">
              <Icon name="gift" size={36} class="text-dark-teal" />
            </div>
            <h3 class="text-2xl mb-2">{plan.name}</h3>
            <p class="text-5xl font-bold text-dark-teal mb-2">{formatPrice(plan.price_cents)}</p>
            <p class="text-black/70 mb-1">{plan.credits} sessions</p>
            {plan.description && <p class="text-black/60 text-sm mb-6">{plan.description}</p>}
            <Button href={membershipsUrl} variant="secondary" target="_blank">Get Started</Button>
          </Card>
        ))}
      </div>
    )}

    {/* Drop-ins & Class Packs */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      {dropIns.map((plan) => (
        <Card variant="dark" class="p-8 text-center">
          <h3 class="text-xl mb-2 text-white">{plan.name}</h3>
          <p class="text-3xl font-bold text-teal mb-1">{formatPrice(plan.price_cents)}</p>
          <p class="text-white/60 text-sm mb-1">{plan.credits} session</p>
          {plan.description && <p class="text-white/50 text-xs mb-6">{plan.description}</p>}
          <Button href={membershipsUrl} variant="on-dark" target="_blank">Buy</Button>
        </Card>
      ))}
      {packs.map((plan) => (
        <Card variant="dark" class="p-8 text-center">
          <h3 class="text-xl mb-2 text-white">{plan.name}</h3>
          <p class="text-3xl font-bold text-teal mb-1">{formatPrice(plan.price_cents)}</p>
          <p class="text-white/60 text-sm mb-1">{plan.credits} sessions</p>
          {plan.price_per_credit && <p class="text-white/50 text-xs mb-1">{formatPrice(plan.price_per_credit)}/session</p>}
          {plan.description && <p class="text-white/50 text-xs mb-6">{plan.description}</p>}
          <Button href={membershipsUrl} variant="on-dark" target="_blank">Buy Pack</Button>
        </Card>
      ))}
    </div>

    {/* Memberships */}
    <h3 class="text-white text-center text-2xl mb-8 mt-12">Monthly Memberships</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {memberships.map((plan) => {
        const isUnlimited = plan.name.includes('Unlimited');
        return isUnlimited ? (
          <Card variant="gold" class="p-8 relative">
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-dark-teal text-white text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full whitespace-nowrap">
              Best Value
            </span>
            <h3 class="text-xl mb-2">{plan.name}</h3>
            <p class="text-3xl font-bold text-dark-teal mb-1">{formatPrice(plan.price_cents)}<span class="text-lg">/mo</span></p>
            {plan.credits && <p class="text-black/60 text-sm mb-1">{plan.credits === 999 ? 'Unlimited' : plan.credits} sessions/month</p>}
            {plan.price_per_credit && plan.credits !== 999 && <p class="text-black/50 text-xs mb-1">{formatPrice(plan.price_per_credit)}/session</p>}
            {plan.description && <p class="text-black/50 text-xs mb-6">{plan.description}</p>}
            <Button href={membershipsUrl} variant="secondary" target="_blank">Subscribe</Button>
          </Card>
        ) : (
          <Card variant="dark" class="p-8 text-center">
            <h3 class="text-xl mb-2 text-white">{plan.name}</h3>
            <p class="text-3xl font-bold text-teal mb-1">{formatPrice(plan.price_cents)}<span class="text-lg">/mo</span></p>
            {plan.credits && <p class="text-white/60 text-sm mb-1">{plan.credits === 999 ? 'Unlimited' : plan.credits} sessions/month</p>}
            {plan.price_per_credit && plan.credits !== 999 && <p class="text-white/50 text-xs mb-1">{formatPrice(plan.price_per_credit)}/session</p>}
            {plan.description && <p class="text-white/50 text-xs mb-6">{plan.description}</p>}
            <Button href={membershipsUrl} variant="on-dark" target="_blank">Subscribe</Button>
          </Card>
        );
      })}
    </div>
  </Section>

  <!-- Private Bookings -->
  <div class="accent-line"></div>
  <Section variant="light" id="private-bookings">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <img
          src="/images/private-rental.jpg"
          alt="Private sauna rental area"
          class="rounded-[var(--radius-card)] w-full h-auto object-cover shadow-lg"
          loading="lazy"
        />
      </div>
      <div>
        <SectionHeading title="Private Bookings" subtitle="Book the entire space for your group, team, or event" align="left" />
        <p class="text-gray-600 mb-4">
          Perfect for corporate wellness, bachelor and bachelorette parties, birthday celebrations, and team recovery sessions.
        </p>
        <p class="text-teal text-2xl font-bold mb-2">Starting at $375</p>
        <p class="text-gray-500 text-sm mb-8">
          Contact us at <a href="mailto:theguys@sauna-guys.com?subject=Private%20Sauna%20Booking%20Inquiry" class="text-teal underline">theguys@sauna-guys.com</a> for availability and custom pricing.
        </p>
        <Button href="mailto:theguys@sauna-guys.com?subject=Private%20Sauna%20Booking%20Inquiry" variant="primary">
          Inquire About Private Sessions
        </Button>
      </div>
    </div>
  </Section>

  <!-- What's Included -->
  <div class="accent-line"></div>
  <Section variant="warm" id="whats-included">
    <SectionHeading title="What's Included" subtitle="Every session comes with everything you need" />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">

      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="shield-check" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Clean Facility</h3>
        <p class="text-gray-600 text-sm">Sanitized space with fresh towels and a pristine environment every session</p>
      </Card>

      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="droplets" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Showers</h3>
        <p class="text-gray-600 text-sm">Full shower facilities available before and after your session</p>
      </Card>

      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="timer" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Full 60 Minutes</h3>
        <p class="text-gray-600 text-sm">Every session gives you the full hour to sauna, plunge, and recover</p>
      </Card>

      <Card variant="clay" class="p-6 text-center">
        <div class="flex justify-center mb-3">
          <Icon name="snowflake" size={36} class="text-teal" />
        </div>
        <h3 class="text-lg mb-2">Cold Plunge Access</h3>
        <p class="text-gray-600 text-sm">Multiple cold plunge tubs maintained at optimal temperatures</p>
      </Card>

    </div>
  </Section>

  <!-- Bottom CTA -->
  <Section variant="dark" id="book-now">
    <div class="text-center">
      <SectionHeading
        title="Ready to Feel the Difference?"
        subtitle="Book your first session today and experience Tampa's premier sauna and cold plunge studio"
        light
      />
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={classesUrl} variant="on-dark" target="_blank">Book a Session</Button>
        <Button href={membershipsUrl} variant="outline" target="_blank">View Memberships</Button>
      </div>
    </div>
  </Section>
</PublicLayout>
