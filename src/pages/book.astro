---
import PublicLayout from '../layouts/PublicLayout.astro';
import HeroImage from '../components/ui/HeroImage.astro';
import Section from '../components/ui/Section.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Card from '../components/ui/Card.astro';
import Icon from '../components/ui/Icon.astro';
import Button from '../components/ui/Button.astro';

const glowfoxClassesUrl = import.meta.env.PUBLIC_GLOWFOX_CLASSES_URL;
const glowfoxMembershipsUrl = import.meta.env.PUBLIC_GLOWFOX_MEMBERSHIPS_URL;
---

<PublicLayout
  title="Book a Session | The Sauna Guys"
  description="Book your sauna and cold plunge session in Tampa. Drop-ins, class packs, and memberships available."
>
  <!-- Hero -->
  <HeroImage src="/images/community.jpg" alt="Community session" height="short">
    <h1>Book Your Session</h1>
    <p class="text-lg max-w-2xl mx-auto">
      Choose a session time, grab a class pack, or sign up for a membership. It only takes a minute.
    </p>
  </HeroImage>

  <div class="accent-line"></div>

  <!-- Booking Options -->
  <Section variant="light">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        <!-- Book a Session -->
        <Card variant="gold" class="p-8 text-center">
          <h2 class="text-2xl mb-4">Book a Session</h2>
          <p class="text-dark-teal/80 mb-6">
            Browse available times and reserve your spot. Drop-ins and class packs accepted.
          </p>
          <Button href={glowfoxClassesUrl} variant="primary" target="_blank">
            View Schedule
          </Button>
        </Card>

        <!-- Memberships -->
        <Card variant="clay" class="p-8 text-center">
          <h2 class="text-2xl mb-4">Memberships</h2>
          <p class="text-gray-600 mb-6">
            Unlimited access, priority booking, and member-only perks. Save on every session.
          </p>
          <Button href={glowfoxMembershipsUrl} variant="primary" target="_blank">
            View Memberships
          </Button>
        </Card>
      </div>

      <!-- GlowFox Embed Placeholder -->
      <div class="mb-16">
        <SectionHeading title="Schedule" />
        <div id="glowfox-embed" class="min-h-[600px] rounded-[20px] border-2 border-gray-200 overflow-hidden">
          <!-- GlowFox iframe will be embedded here -->
          <div class="flex flex-col items-center justify-center h-[600px] bg-gray-50 text-center px-8">
            <p class="text-gray-500 text-lg mb-6">
              Loading booking calendar...
            </p>
            <p class="text-gray-400 mb-6">
              If the calendar does not load, you can book directly on our scheduling platform.
            </p>
            <Button href={glowfoxClassesUrl} variant="primary" target="_blank">
              Book on GlowFox
            </Button>
          </div>
        </div>
      </div>

      <!-- Quick Info -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
        <Card variant="clay" class="p-6">
          <div class="text-3xl font-bold text-dark-teal mb-2">$39</div>
          <p class="font-bold">Drop-In</p>
          <p class="text-gray-500 text-sm">Single session</p>
        </Card>
        <Card variant="gold" class="p-6">
          <div class="text-3xl font-bold text-dark-teal mb-2">$60</div>
          <p class="font-bold">Sauna Sampler</p>
          <p class="text-dark-teal/70 text-sm">3 sessions</p>
        </Card>
        <Card variant="clay" class="p-6">
          <div class="text-3xl font-bold text-dark-teal mb-2">$120+</div>
          <p class="font-bold">Membership</p>
          <p class="text-gray-500 text-sm">Monthly unlimited</p>
        </Card>
      </div>

      <!-- First-timer callout -->
      <div class="mt-12 text-center">
        <p class="text-gray-600">
          First time? <a href="/first-visit" class="text-teal font-bold hover:underline">Read our first-visit guide</a> to know exactly what to expect.
        </p>
      </div>
    </div>
  </Section>
</PublicLayout>
