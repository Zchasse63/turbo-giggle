---
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';

const navLinks = [
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/faq', label: 'FAQ' },
  { href: '/gifts', label: 'Gift Cards' },
];

const bookingUrl = import.meta.env.PUBLIC_GLOWFOX_CLASSES_URL;
const currentPath = Astro.url.pathname;

/**
 * Determine if a nav link is the current page.
 * Matches exact path or any sub-path (e.g. /blog matches /blog/post-slug).
 */
function isCurrent(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="bg-dark-teal sticky top-0 z-50">
  <nav class="container flex items-center justify-between py-4">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0 cursor-pointer">
      <img
        src="/images/logo.png"
        alt="The Sauna Guys"
        width="60"
        height="60"
        class="rounded-full"
      />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="font-display text-white text-[1.875rem] leading-none uppercase tracking-wide hover:text-teal transition-colors duration-200 cursor-pointer"
            aria-current={isCurrent(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA Button (desktop) -->
    <div class="hidden md:block">
      <Button href={bookingUrl} variant="on-dark" target="_blank">
        Book Class
      </Button>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden text-white p-2 cursor-pointer"
      aria-label="Toggle mobile menu"
      aria-expanded="false"
    >
      <span id="menu-icon-open">
        <Icon name="menu" size={28} />
      </span>
      <span id="menu-icon-close" class="hidden">
        <Icon name="x" size={28} />
      </span>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div
    id="mobile-menu"
    class="md:hidden bg-dark-teal border-t border-white/10 overflow-hidden transition-all duration-300 ease-in-out"
    style="max-height: 0;"
  >
    <ul class="container flex flex-col gap-4 py-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link font-display text-white text-[1.875rem] leading-none uppercase tracking-wide block py-2 hover:text-teal transition-colors duration-200 cursor-pointer"
            aria-current={isCurrent(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <Button href={bookingUrl} variant="on-dark" target="_blank">
          Book Class
        </Button>
      </li>
    </ul>
  </div>

  <!-- Yellow accent line at BOTTOM of header -->
  <div class="h-[3px] bg-yellow"></div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  function openMenu() {
    if (!menu || !iconOpen || !iconClose || !toggle) return;
    menu.style.maxHeight = menu.scrollHeight + 'px';
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
    toggle.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    if (!menu || !iconOpen || !iconClose || !toggle) return;
    menu.style.maxHeight = '0';
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
    toggle.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  // Close menu when a nav link is clicked (SPA-like behavior)
  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      closeMenu();
    });
  });
</script>
