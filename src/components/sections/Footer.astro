---
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';

const bookingUrl = import.meta.env.PUBLIC_GLOWFOX_CLASSES_URL;
---

<footer class="section-dark" style="padding: 0;">
  <!-- Yellow accent line at TOP of footer -->
  <div class="accent-line"></div>

  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <img
          src="/images/logo.png"
          alt="The Sauna Guys"
          width="80"
          height="80"
          class="rounded-full mb-4"
        />
        <p class="text-white/70 text-sm max-w-xs">
          Tampa's premier sauna and cold plunge wellness studio. Guided contrast therapy for recovery, stress relief, and total body wellness.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h6 class="text-teal font-bold uppercase tracking-wider mb-4">Quick Links</h6>
        <ul class="space-y-2">
          <li>
            <a href="/services" class="text-white/70 hover:text-white hover:underline transition-all duration-200 text-sm cursor-pointer">
              Services &amp; Pricing
            </a>
          </li>
          <li>
            <a href="/about" class="text-white/70 hover:text-white hover:underline transition-all duration-200 text-sm cursor-pointer">
              About Us
            </a>
          </li>
          <li>
            <a href="/first-visit" class="text-white/70 hover:text-white hover:underline transition-all duration-200 text-sm cursor-pointer">
              First Visit Guide
            </a>
          </li>
          <li>
            <a href="/blog" class="text-white/70 hover:text-white hover:underline transition-all duration-200 text-sm cursor-pointer">
              Blog
            </a>
          </li>
          <li>
            <a href="/faq" class="text-white/70 hover:text-white hover:underline transition-all duration-200 text-sm cursor-pointer">
              FAQ
            </a>
          </li>
          <li>
            <a href="/gifts" class="text-white/70 hover:text-white hover:underline transition-all duration-200 text-sm cursor-pointer">
              Gift Cards
            </a>
          </li>
          <li>
            <a href="/contact" class="text-white/70 hover:text-white hover:underline transition-all duration-200 text-sm cursor-pointer">
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Location -->
      <div>
        <h6 class="text-teal font-bold uppercase tracking-wider mb-4">Visit Us</h6>
        <address class="not-italic text-white/70 text-sm space-y-1">
          <p>1703 North 24th Street</p>
          <p>Tampa, FL 33605</p>
          <p class="pt-2">
            <a href="tel:+18135514177" class="hover:text-white hover:underline transition-all duration-200 cursor-pointer">
              (813) 551-4177
            </a>
          </p>
          <p>
            <a href="mailto:hello@thesaunaguys.com" class="hover:text-white hover:underline transition-all duration-200 cursor-pointer">
              hello@thesaunaguys.com
            </a>
          </p>
        </address>
        <div class="mt-4">
          <Button href={bookingUrl} variant="on-dark" target="_blank">
            Book a Session
          </Button>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/50 text-xs">
        &copy; 2025 The Sauna Guys. All rights reserved.
      </p>
      <div class="flex gap-4">
        <a
          href="https://www.instagram.com/thesaunaguys/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white/50 hover:text-teal transition-colors duration-200 cursor-pointer"
          aria-label="Instagram"
        >
          <Icon name="instagram" size={20} />
        </a>
        <a
          href="https://www.facebook.com/thesaunaguystampa/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white/50 hover:text-teal transition-colors duration-200 cursor-pointer"
          aria-label="Facebook"
        >
          <Icon name="facebook" size={20} />
        </a>
      </div>
    </div>
  </div>
</footer>
