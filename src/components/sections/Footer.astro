---
const currentYear = new Date().getFullYear();
const bookingUrl = import.meta.env.PUBLIC_GLOWFOX_CLASSES_URL;
---

<footer class="section-dark">
  <div class="accent-line"></div>
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <img
          src="/images/logo.png"
          alt="The Sauna Guys"
          width="80"
          height="80"
          class="rounded-full mb-4"
        />
        <p class="text-white/70 text-sm max-w-xs">
          Tampa's premier sauna and cold plunge wellness studio. Guided contrast therapy for recovery, stress relief, and total body wellness.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h6 class="text-teal font-bold uppercase tracking-wider mb-4">Quick Links</h6>
        <ul class="space-y-2">
          <li><a href="/services" class="text-white/70 hover:text-white transition-colors text-sm">Services & Pricing</a></li>
          <li><a href="/about" class="text-white/70 hover:text-white transition-colors text-sm">About Us</a></li>
          <li><a href="/first-visit" class="text-white/70 hover:text-white transition-colors text-sm">First Visit Guide</a></li>
          <li><a href="/faq" class="text-white/70 hover:text-white transition-colors text-sm">FAQ</a></li>
          <li><a href="/blog" class="text-white/70 hover:text-white transition-colors text-sm">Blog</a></li>
          <li><a href="/contact" class="text-white/70 hover:text-white transition-colors text-sm">Contact</a></li>
        </ul>
      </div>

      <!-- Location -->
      <div>
        <h6 class="text-teal font-bold uppercase tracking-wider mb-4">Visit Us</h6>
        <address class="not-italic text-white/70 text-sm space-y-1">
          <p>3709 W Azeele St.</p>
          <p>Tampa, FL 33609</p>
          <p class="pt-2">
            <a href="tel:+18135514177" class="hover:text-white transition-colors">(813) 551-4177</a>
          </p>
          <p>
            <a href="mailto:info@thesaunaguys.com" class="hover:text-white transition-colors">info@thesaunaguys.com</a>
          </p>
        </address>
        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center mt-4 px-6 py-2 bg-teal text-black font-bold uppercase text-xs tracking-wider rounded-[60px] hover:brightness-110 transition-all"
        >
          Book a Session
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/50 text-xs">
        &copy; {currentYear} The Sauna Guys. All rights reserved.
      </p>
      <div class="flex gap-4">
        <a href="https://www.instagram.com/thesaunaguys/" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-teal transition-colors" aria-label="Instagram">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="https://www.facebook.com/thesaunaguystampa/" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-teal transition-colors" aria-label="Facebook">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385h-3.047v-3.47h3.047v-2.642c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.514c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385c5.738-.9 10.126-5.864 10.126-11.854z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
